# ══════════════════════════════════════════════════════════════════════════════
# BizManager — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── App environment ───────────────────────────────────────────────────────────
# "development"  → OTP printed to console; real email only if SMTP is set
# "production"   → OTP only via real email/SMS; error shown if not configured
APP_ENV=development

# ── Flask secret key ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BMS_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING

# ── Database ──────────────────────────────────────────────────────────────────
# Leave empty for SQLite (development).
# Set for PostgreSQL (production):
# DATABASE_URL=postgresql://bmsuser:password@localhost:5432/bizmanager

# ── OTP settings ─────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# ══════════════════════════════════════════════════════════════════════════════
# EMAIL — SMTP (works with Gmail, Outlook, Zoho, any SMTP server)
# ══════════════════════════════════════════════════════════════════════════════
# When SMTP_USER + SMTP_PASS are both set, real emails are sent automatically
# in BOTH development and production. OTP is also still printed to console in dev.
#
# Gmail setup:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to: Google Account → Security → App Passwords
#   3. Create an app password for "Mail"
#   4. Paste the 16-character password in SMTP_PASS below
#
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587

SMTP_USER=your_brevo_smtp_login
SMTP_PASS=your_brevo_smtp_key

SMTP_FROM=BizManager <your_verified_sender@example.com>

# ── SendGrid (alternative to SMTP) ───────────────────────────────────────────
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx

# ── AWS SES (alternative to SMTP) ────────────────────────────────────────────
# EMAIL_PROVIDER=ses
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxx

# ══════════════════════════════════════════════════════════════════════════════
# SMS — choose ONE provider (only needed for production mobile OTP)
# In development, SMS OTP is always shown in the console.
# ══════════════════════════════════════════════════════════════════════════════

# ── Fast2SMS (recommended for India — easy signup at fast2sms.com) ────────────
SMS_PROVIDER=fast2sms
# FAST2SMS_API_KEY=your_api_key_here

# ── Twilio ────────────────────────────────────────────────────────────────────
# SMS_PROVIDER=twilio
# TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM=+1XXXXXXXXXX

# ── MSG91 (another India-friendly option) ────────────────────────────────────
# SMS_PROVIDER=msg91
# MSG91_AUTH_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
# MSG91_TEMPLATE_ID=xxxxxxxxxxxxxxxxx
# MSG91_SENDER_ID=BIIZMG
